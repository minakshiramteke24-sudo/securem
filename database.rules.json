{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "messages": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "user-chats": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "stories": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "reels": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reelId": {
        "likes": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "comments": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },

    "transfers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "typing": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "calls": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
